# ============================================
# ZivonPay Environment Configuration Template
# ============================================
# Copy this file to .env.development or .env.production
# and fill in the values.
#
# Usage:
#   Development: APP_ENV=development uvicorn app.main:app
#   Production:  APP_ENV=production uvicorn app.main:app
#
# The APP_ENV variable selects which .env.{APP_ENV} file to load.
# Defaults to "development" if not set.
# Falls back to .env if .env.{APP_ENV} doesn't exist.
# ============================================

# Environment Configuration
ENVIRONMENT=sandbox          # sandbox | production
DEBUG=false                  # true | false

# IP Whitelist (comma-separated, leave empty to allow all)
ALLOWED_IPS=

# Supabase Configuration (Optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# SprintNXT UPI Configuration
SPRINTNXT_BASE_URL=
SPRINTNXT_CLIENT_ID=
SPRINTNXT_TOKEN=
SPRINTNXT_API_ID=20260
SPRINTNXT_BANK_ID=3
SPRINTNXT_PAYEE_VPA=

# Security
JWT_SECRET_KEY=              # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=              # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# API Configuration
API_V1_PREFIX=/v1
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_ORDERS_CREATE=1000
RATE_LIMIT_ORDERS_FETCH=5000

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_COUNT=3
WEBHOOK_REPLAY_TOLERANCE=300

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json              # json | text
