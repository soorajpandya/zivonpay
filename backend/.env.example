# Environment Configuration
ENVIRONMENT=sandbox

# Database Configuration
DATABASE_URL=postgresql+asyncpg://zivonpay:password@localhost:5432/zivonpay_sandbox
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# SprintNXT UPI Configuration (SANDBOX)
SPRINTNXT_BASE_URL=https://nxt-nonprod.sprintnxt.in/NonProdNextgenAPIExpose/api/v2/UPIService/UPI
SPRINTNXT_CLIENT_ID=your_client_id_here
SPRINTNXT_TOKEN=your_token_here
SPRINTNXT_API_ID=20260
SPRINTNXT_BANK_ID=3
SPRINTNXT_PAYEE_VPA=ps1.sprintnxt@fin

# Security
JWT_SECRET_KEY=change_this_to_a_secure_random_string_min_32_chars
ENCRYPTION_KEY=change_this_to_32_byte_key_for_aes256_encryption

# API Configuration
API_V1_PREFIX=/v1
API_TITLE=ZivonPay API
API_VERSION=1.0.0
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_ORDERS_CREATE=1000
RATE_LIMIT_ORDERS_FETCH=5000

# Monitoring
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_COUNT=3
WEBHOOK_REPLAY_TOLERANCE=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
