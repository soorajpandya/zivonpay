{
  "info": {
    "name": "ZivonPay API",
    "_postman_id": "zivonpay-api-collection-v1",
    "description": "Complete API collection for ZivonPay — UPI Payment Aggregator.\n\n## Getting Started\n1. Import this collection and one of the environment files (sandbox / production)\n2. Run the **Signup** request to get your API keys\n3. Your sandbox_key_id and sandbox_key_secret are auto-saved to the environment\n4. All endpoints use HTTP Basic Auth (key_id:key_secret) — injected automatically\n\n## HMAC Request Signing\nIf you have request signing enabled, set the `signing_secret` environment variable.\nThe pre-request script will automatically compute `x-timestamp` and `x-signature` headers.\n\n## Environments\n- **Sandbox** — test mode (zp_test_* keys), no real money\n- **Production** — live transactions (zp_live_* keys)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{sandbox_key_id}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{sandbox_key_secret}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set Content-Type for POST/PUT requests",
          "if (pm.request.method === 'POST' || pm.request.method === 'PUT') {",
          "    pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}",
          "",
          "// HMAC Request Signing (if signing_secret is set)",
          "const signingSecret = pm.environment.get('signing_secret');",
          "if (signingSecret) {",
          "    const timestamp = Math.floor(Date.now() / 1000).toString();",
          "    const method = pm.request.method;",
          "    const url = new URL(pm.request.url.toString());",
          "    const path = url.pathname;",
          "    const body = pm.request.body ? pm.request.body.raw || '' : '';",
          "    const bodyHash = CryptoJS.SHA256(body).toString();",
          "    const canonical = method + '\\n' + path + '\\n' + bodyHash + '\\n' + timestamp;",
          "    const signature = CryptoJS.HmacSHA256(canonical, signingSecret).toString();",
          "    pm.request.headers.upsert({ key: 'x-timestamp', value: timestamp });",
          "    pm.request.headers.upsert({ key: 'x-signature', value: signature });",
          "    console.log('Request signed: ' + method + ' ' + path);",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global: verify response time < 5s",
          "pm.test('Response time < 5s', () => pm.expect(pm.response.responseTime).to.be.below(5000));",
          "",
          "// Global: response has request ID",
          "pm.test('Has X-Request-ID header', () => pm.expect(pm.response.headers.has('X-Request-ID')).to.be.true);"
        ]
      }
    }
  ],
  "variable": [
    { "key": "base_url", "value": "https://api.zivonpay.com" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Merchant authentication — signup and login",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Has sandbox credentials', () => {",
                  "    pm.expect(body).to.have.property('sandbox_credentials');",
                  "    pm.expect(body.sandbox_credentials).to.have.property('key_id');",
                  "    pm.expect(body.sandbox_credentials).to.have.property('key_secret');",
                  "});",
                  "",
                  "pm.test('Has live credentials', () => {",
                  "    pm.expect(body).to.have.property('live_credentials');",
                  "});",
                  "",
                  "// Save credentials",
                  "if (body.sandbox_credentials) {",
                  "    pm.environment.set('sandbox_key_id', body.sandbox_credentials.key_id);",
                  "    pm.environment.set('sandbox_key_secret', body.sandbox_credentials.key_secret);",
                  "}",
                  "if (body.live_credentials) {",
                  "    pm.environment.set('live_key_id', body.live_credentials.key_id);",
                  "    pm.environment.set('live_key_secret', body.live_credentials.key_secret);",
                  "}",
                  "if (body.auth && body.auth.access_token) {",
                  "    pm.environment.set('access_token', body.auth.access_token);",
                  "}",
                  "if (body.webhook_secret) {",
                  "    pm.environment.set('webhook_secret', body.webhook_secret);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"business_name\": \"My Test Business\",\n    \"email\": \"test@example.com\",\n    \"password\": \"SecurePass123!\",\n    \"webhook_url\": \"https://example.com/webhook\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "signup"]
            },
            "description": "Register a new merchant. Returns sandbox + live API keys and a JWT token."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Has access_token', () => pm.expect(body).to.have.property('access_token'));",
                  "",
                  "// Auto-save token",
                  "if (body.access_token) {",
                  "    pm.environment.set('access_token', body.access_token);",
                  "    console.log('Token saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"SecurePass123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "login"]
            },
            "description": "Login and get a JWT access token. Token is auto-saved to environment."
          }
        }
      ]
